<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_showtime"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Movie Title -->
        <TextView
            android:id="@+id/tv_showtime_movie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Movie Title"
            android:textColor="@color/primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Theater Name -->
        <TextView
            android:id="@+id/tv_showtime_theater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Theater Name"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="10dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="10dp" />

        <!-- Date / Time / Seats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_showtime_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngày: 2024-03-15"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_showtime_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giờ: 14:00"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tv_showtime_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giá: 90.000 VND"
                    android:textColor="@color/price_color"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_showtime_seats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Còn 40 ghế trống"
                    android:textColor="@color/seat_available"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Book Button -->
        <Button
            android:id="@+id/btn_book_showtime"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Đặt vé"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primary" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
